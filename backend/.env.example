# Copy to backend/.env and adjust. All variables are optional.

# Folder preconfigured as the first library root on first run.
# WSL example (Windows D:\Books):
#   LIBRARY_ROOT=/mnt/d/Books
# macOS/Linux example:
#   LIBRARY_ROOT=/home/you/Books
LIBRARY_ROOT=

# Where the SQLite database and cached covers are stored.
# Defaults to backend/data.
# LIBRARY_DATA_DIR=/absolute/path/to/data
